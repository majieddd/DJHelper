# ---- Spotify (OPTIONAL) ----
# Leave these blank! DJHelper reads PUBLIC playlists with no credentials.
# Only fill these in if you need PRIVATE playlists: create a free app at
# https://developer.spotify.com/dashboard and paste its Client ID / Secret.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ---- Traktor ----
# The name of your macOS boot drive as shown in Finder (used to build the
# file paths inside the Traktor .nml collection). Usually "Macintosh HD".
TRAKTOR_VOLUME=Macintosh HD

# ---- Local AI (optional) ----
# Install Ollama (https://ollama.com) then: `ollama pull gemma4:e2b`
# gemma4:e2b is a small, fast edge model. Fallbacks: gemma3n:e2b, gemma2:2b.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# ---- Paths (optional overrides) ----
# DJHELPER_DATA_DIR=./data
# DJHELPER_MUSIC_DIR=./data/music
# DJHELPER_EXPORT_DIR=./data/exports

# How many beats before the end to place the "Mix Out" hot cue.
DJHELPER_MIX_OUT_BEATS=32
