# ---- Spotify (required to import playlists) ----
# Create a free app at https://developer.spotify.com/dashboard
# then copy its Client ID / Client Secret here.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ---- Traktor ----
# The name of your macOS boot drive as shown in Finder (used to build the
# file paths inside the Traktor .nml collection). Usually "Macintosh HD".
TRAKTOR_VOLUME=Macintosh HD

# ---- Local AI (optional) ----
# Install Ollama (https://ollama.com) then: `ollama pull gemma2:2b`
# Bigger / better: gemma2:9b  (or gemma3:12b if you have the RAM/VRAM).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# ---- Paths (optional overrides) ----
# DJHELPER_DATA_DIR=./data
# DJHELPER_MUSIC_DIR=./data/music
# DJHELPER_EXPORT_DIR=./data/exports

# How many beats before the end to place the "Mix Out" hot cue.
DJHELPER_MIX_OUT_BEATS=32
